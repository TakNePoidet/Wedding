---
import { CHAT_URL, RULES } from '../data/wedding';
/** ПРАВИЛА ВЕЧЕРА — светлая washed-полоса */
---

<section class="rules" id="rules" aria-labelledby="rules-h">
  <svg class="botanical botanical--rules" aria-hidden="true"><use href="#sprig-grass" /></svg>
  <div class="shell rules__grid reveal">
    <div class="rules__lead">
      <h2 class="head" id="rules-h">хорошо<br />знать</h2>
      <p class="rules__note">
        Несколько мягких просьб, чтобы вечер получился таким, как мы&nbsp;его задумали.
      </p>
    </div>
    <ul class="rules__list stagger">
      {
        RULES.map((rule) => (
          <li>
            <span class="rules__k" set:html={rule.k} />
            <span class="rules__v" set:html={rule.v} />
          </li>
        ))
      }
    </ul>
    <div class="rules__cta">
      <a class="link-btn" id="tg-chat" href={CHAT_URL || '#'} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="19" height="19" fill="none" aria-hidden="true"
          ><path
            d="M21 4.5 3.6 11.3c-.9.35-.88 1.65.03 1.97l4.3 1.5 1.66 5.02c.27.8 1.32.96 1.82.28l2.35-3.2 4.4 3.24c.62.46 1.5.12 1.66-.63L22.9 5.6c.2-.9-.7-1.64-1.9-1.1Z"
            stroke="currentColor"
            stroke-width="1.3"
            stroke-linejoin="round"></path></svg
        >
        <span>вступить в&nbsp;чат праздника</span>
      </a>
      <p class="rules__hint" id="tg-hint" aria-live="polite" hidden>
        Ссылку на&nbsp;чат добавим ближе к&nbsp;дате&nbsp;— загляните сюда позже.
      </p>
    </div>
  </div>
</section>

<script>
  import '../scripts/tg-chat';
</script>
