---
import { DATE_DOTTED, VENUE } from '../data/wedding';
/** FOOTER */
---

<footer
  class="relative z-1 bg-linear-to-b from-green-deep to-[#232e1c] text-cream-1 text-center pt-[clamp(3.5rem,9vw,6rem)] pb-[clamp(3rem,7vw,4.5rem)] px-[var(--pad)]"
>
  <svg class="sprig-inline sprig-inline--foot" aria-hidden="true"><use href="#sprig-euc" /></svg>
  <p class="font-script text-4xl text-cream-0 mt-0 mb-[0.4rem]">
    с&nbsp;любовью, Никита <span class="text-beige">и</span> Лера
  </p>
  <p class="italic tracking-wider text-sage-1 m-0">{DATE_DOTTED} — {VENUE.city}</p>
</footer>
