---
import { DETAILS } from '../data/wedding';
/** ДЕТАЛИ — асимметричный разворот, без карточек */
---

<section class="py-[var(--sy)]" id="details" aria-labelledby="details-h">
  <div
    class="shell reveal grid items-start gap-[clamp(var(--spacing-md),5vw,var(--spacing-xl))] grid-cols-[0.58fr_1.42fr] max-md:grid-cols-1"
  >
    <div class="details__lead relative">
      <h2 class="head text-3xl" id="details-h">коротко<br />о&nbsp;главном</h2>
      <svg class="sprig-inline" aria-hidden="true"><use href="#sprig-euc" /></svg>
    </div>
    <ul class="stagger m-0 list-none p-0">
      {
        DETAILS.map((row) => (
          <li class="grid items-baseline gap-x-lg gap-y-2xs border-t border-brown-2/28 py-md grid-cols-[minmax(6rem,max-content)_1fr] max-md:grid-cols-1 max-md:gap-x-[0.15rem] max-md:gap-y-[0.15rem]">
            <span class="text-sm italic text-brown-2" set:html={row.k} />
            <span class="details__v font-text text-base leading-normal text-green-deep">
              <Fragment set:html={row.v} />
              {'anchor' in row && row.anchor && (
                <a class="link-btn mt-xs flex w-fit text-sm" href={row.anchor.href}>
                  <svg viewBox="0 0 24 24" width="17" height="17" fill="none" aria-hidden="true">
                    <path
                      d="M12 21s7-6.2 7-11a7 7 0 1 0-14 0c0 4.8 7 11 7 11Z"
                      stroke="currentColor"
                      stroke-width="1.3"
                      stroke-linejoin="round"
                    />
                    <circle cx="12" cy="10" r="2.4" stroke="currentColor" stroke-width="1.3" />
                  </svg>
                  <span>{row.anchor.label}</span>
                </a>
              )}
            </span>
          </li>
        ))
      }
      <li class="block border-t border-b border-brown-2/28 py-md">
        <button class="link-btn" id="ics-btn" type="button">
          <svg viewBox="0 0 24 24" width="19" height="19" fill="none" aria-hidden="true"
            ><rect x="3.5" y="5" width="17" height="15" rx="2" stroke="currentColor" stroke-width="1.3"
            ></rect><path
              d="M3.5 9.5h17M8 3.5v3M16 3.5v3"
              stroke="currentColor"
              stroke-width="1.3"
              stroke-linecap="round"></path><path
              d="M12 17.4c-1.9-1.2-3.1-2.3-3.1-3.6 0-1.8 2.1-2.3 3.1-.9 1-1.4 3.1-.9 3.1.9 0 1.3-1.2 2.4-3.1 3.6Z"
              fill="currentColor"></path></svg
          >
          <span>сохранить дату в&nbsp;календарь</span>
        </button>
      </li>
    </ul>
  </div>
</section>

<script>
  import '../scripts/calendar';
</script>
